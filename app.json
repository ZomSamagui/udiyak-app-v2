{
  "expo": {
    "name": "udiyak-app-v2",
    "slug": "udiyak-app-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "assets": [
      "./assets/fonts/"
    ],
    "fonts": [
      {
        "asset": "./assets/fonts/Stunning.otf",
        "name": "Stunning"
      },
      {
        "assets": "./assets/fonts/TheJamsilBold.otf",
        "name": "TheJamsilBold"
      },
      {
        "assets": "./assets/fonts/TheJamsilMedium.otf",
        "name": "TheJamsilMedium"
      },
      {
        "assets": "./assets/fonts/TheJamsilRegular.otf",
        "name": "TheJamsilRegular"
      }
    ]
  }
}
