{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "navigation/*": ["Navigation/*"],
      "assets/*": ["Assets/*"],
      "components/*": ["Components/*"],
      "constants/*": ["Constants/*"],
      "hooks/*": ["Hooks/*"],
      "lib/*": ["Lib/*"],
      "screens/*": ["Screens/*"],
      "type/*": ["Type/*"],
    }
  },
  "include": [
    "**/*",
    "@Types/**/*",
    "Navigation/**/*",
    "Assets/**/*",
    "Components/**/*",
    "Hooks/**/*",
    "Lib/**/*",
    "Screens/**/*",
    "Type/**/*"
  ]
}
