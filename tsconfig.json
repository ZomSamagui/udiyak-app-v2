{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "navigation/*": ["navigation/*"],
      "assets/*": ["assets/*"],
      "components/*": ["components/*"],
      "constants/*": ["constants/*"],
      "hooks/*": ["hooks/*"],
      "lib/*": ["lib/*"],
      "navigation/*": ["navigation/*"],
      "screens/*": ["screens/*"],
      "type/*": ["type/*"],
    }
  },
  "include": [
    "**/*",
    "@Types/**/*",
    "Navigation/**/*",
    "Assets/**/*",
    "Components/**/*",
    "Hooks/**/*",
    "Lib/**/*",
    "Screens/**/*",
    "Type/**/*"
  ]
}
